# leaf-ios is a standalone workspace with its own target dir (the root
# .gitignore's `/target` only covers the main workspace).
/target

# Xcode build output (derivedDataPath points here) — large and regenerable.
/ios/build

# Generated by `xcodegen generate` from ios/project.yml — regenerable, so not
# checked in. Run `cd ios && xcodegen generate` to recreate it.
/ios/*.xcodeproj

.DS_Store
